<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TokenID — Onboarding Demo</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg:        #0F1117;
    --bg-2:      #161925;
    --card:      #1E2540;
    --card-2:    #252C4A;
    --border:    #2A3050;
    --border-2:  #3A4060;
    --text:      #FFFFFF;
    --text-2:    #A8ADC5;
    --text-3:    #6E7490;
    --orange:    #FE602C;
    --teal:      #00BFA6;
    --blue:      #378ADD;
    --amber:     #EF9F27;
    --red:       #E24B4A;
    --green:     #1D9E75;
    --purple:    #7F77DD;
    --mono:      'SF Mono', 'Monaco', 'Consolas', monospace;
    --sans:      -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  html, body {
    height: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.5;
    overflow: hidden;
  }

  /* ───── Layout ───── */
  .app {
    display: flex;
    flex-direction: column;
    height: 100vh;
  }

  .browser-frame {
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .browser-dots { display: flex; gap: 6px; }
  .browser-dots span {
    width: 11px; height: 11px; border-radius: 50%;
  }
  .browser-dots span:nth-child(1) { background: #E24B4A; }
  .browser-dots span:nth-child(2) { background: #EF9F27; }
  .browser-dots span:nth-child(3) { background: #1D9E75; }
  .browser-url {
    flex: 1;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 12px;
    color: var(--text-2);
    font-family: var(--mono);
  }
  .demo-controls { display: flex; gap: 6px; align-items: center; }
  .demo-badge {
    background: rgba(254, 96, 44, 0.15);
    color: var(--orange);
    font-size: 11px;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 4px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .demo-btn {
    background: transparent;
    border: 1px solid var(--border-2);
    color: var(--text-2);
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 4px;
    cursor: pointer;
    font-family: var(--sans);
  }
  .demo-btn:hover { background: var(--card); color: var(--text); }

  .progress-rail {
    display: flex;
    align-items: center;
    padding: 12px 32px;
    gap: 8px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
    overflow-x: auto;
  }
  .step-dot {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    white-space: nowrap;
  }
  .step-dot .circle {
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--card);
    border: 1px solid var(--border-2);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 500; color: var(--text-3);
    transition: all .2s;
  }
  .step-dot.active .circle { background: var(--orange); color: #fff; border-color: var(--orange); }
  .step-dot.complete .circle { background: var(--green); color: #fff; border-color: var(--green); }
  .step-dot .label {
    font-size: 11px; color: var(--text-3); font-weight: 500;
  }
  .step-dot.active .label { color: var(--text); }
  .step-dot.complete .label { color: var(--text-2); }
  .step-sep { flex: 1; height: 1px; background: var(--border); min-width: 16px; }

  .stage {
    flex: 1;
    overflow-y: auto;
    padding: 40px 24px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }
  .stage-inner { width: 100%; max-width: 900px; }

  .hidden { display: none !important; }

  /* ───── Hero / landing ───── */
  .hero { text-align: center; padding: 20px 0; }
  .hero-eyebrow {
    display: inline-block;
    background: rgba(254, 96, 44, 0.12);
    color: var(--orange);
    font-size: 11px;
    font-weight: 500;
    padding: 4px 12px;
    border-radius: 20px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .hero h1 {
    font-size: 42px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }
  .hero h1 .accent { color: var(--orange); }
  .hero-sub {
    font-size: 17px;
    color: var(--text-2);
    max-width: 600px;
    margin: 0 auto 32px;
    line-height: 1.5;
  }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    max-width: 640px;
    margin: 0 auto 32px;
  }
  .hero-stat {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 12px;
    text-align: left;
  }
  .hero-stat .n { font-size: 20px; font-weight: 600; margin-bottom: 2px; }
  .hero-stat .l { font-size: 11px; color: var(--text-3); }

  .cta-group {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-bottom: 16px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 11px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    border: none;
    font-family: var(--sans);
    transition: all .15s;
  }
  .btn-primary {
    background: var(--orange);
    color: #fff;
  }
  .btn-primary:hover { background: #ff7343; }
  .btn-ghost {
    background: transparent;
    border: 1px solid var(--border-2);
    color: var(--text);
  }
  .btn-ghost:hover { background: var(--card); }
  .btn-green { background: var(--green); color: #fff; }
  .btn-green:hover { background: #23b388; }
  .cta-meta { font-size: 12px; color: var(--text-3); }

  .logo-row {
    display: flex;
    justify-content: center;
    gap: 28px;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .logo-row span {
    font-size: 13px; color: var(--text-3); font-weight: 500;
    letter-spacing: 0.3px;
  }

  /* ───── Signup ───── */
  .signup-card {
    max-width: 460px;
    margin: 0 auto;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px;
  }
  .signup-card h2 {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .signup-card .sub {
    font-size: 13px;
    color: var(--text-2);
    margin-bottom: 24px;
  }
  .oauth-btn {
    width: 100%;
    padding: 11px;
    border-radius: 8px;
    background: #24292e;
    color: #fff;
    border: 1px solid #2a2f36;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .oauth-btn:hover { background: #2a2f36; }
  .divider-or {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 16px 0;
    color: var(--text-3);
    font-size: 11px;
  }
  .divider-or::before, .divider-or::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }
  .field-group { margin-bottom: 12px; }
  .field-group label {
    display: block;
    font-size: 12px;
    color: var(--text-2);
    margin-bottom: 6px;
    font-weight: 500;
  }
  .field-group input {
    width: 100%;
    padding: 10px 12px;
    background: var(--bg);
    border: 1px solid var(--border-2);
    border-radius: 7px;
    color: var(--text);
    font-size: 14px;
    font-family: var(--sans);
  }
  .field-group input:focus {
    outline: none;
    border-color: var(--orange);
  }
  .privacy-note {
    font-size: 11px;
    color: var(--text-3);
    line-height: 1.5;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }
  .privacy-note a { color: var(--teal); text-decoration: none; }

  /* ───── Connect method ───── */
  .connect-wrap { max-width: 680px; margin: 0 auto; }
  .connect-wrap h2 {
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .connect-wrap .lead {
    color: var(--text-2);
    margin-bottom: 28px;
  }
  .option {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 18px 20px;
    margin-bottom: 12px;
    cursor: pointer;
    transition: all .15s;
  }
  .option:hover { border-color: var(--border-2); background: var(--card-2); }
  .option.recommended {
    border-color: var(--green);
    background: linear-gradient(to right, rgba(29, 158, 117, 0.08), transparent 30%);
  }
  .option-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }
  .option-title {
    font-size: 15px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .option-badge {
    font-size: 11px;
    padding: 3px 9px;
    border-radius: 12px;
    font-weight: 500;
  }
  .badge-green { background: rgba(29, 158, 117, 0.15); color: var(--green); }
  .badge-amber { background: rgba(239, 159, 39, 0.15); color: var(--amber); }
  .badge-purple { background: rgba(127, 119, 221, 0.15); color: var(--purple); }
  .option-sub { font-size: 13px; color: var(--text-2); line-height: 1.5; }
  .option-chevron { color: var(--text-3); font-size: 18px; }

  /* ───── SDK setup ───── */
  .setup-wrap { max-width: 700px; margin: 0 auto; }
  .setup-wrap h2 {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .setup-wrap .lead {
    color: var(--text-2);
    margin-bottom: 20px;
  }
  .tabs {
    display: flex;
    gap: 2px;
    background: var(--card);
    padding: 3px;
    border-radius: 8px;
    border: 1px solid var(--border);
    width: fit-content;
    margin-bottom: 16px;
  }
  .tab {
    padding: 6px 14px;
    border-radius: 5px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-3);
    cursor: pointer;
    border: none;
    background: transparent;
    font-family: var(--sans);
  }
  .tab.active {
    background: var(--card-2);
    color: var(--text);
  }
  .code-block {
    background: #0B0D12;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 18px;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.8;
    margin-bottom: 14px;
    position: relative;
    overflow-x: auto;
  }
  .code-block .copy-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    background: var(--card);
    border: 1px solid var(--border-2);
    color: var(--text-3);
    font-size: 10px;
    padding: 4px 8px;
    border-radius: 4px;
    cursor: pointer;
    font-family: var(--sans);
  }
  .code-comment { color: #6E7490; }
  .code-key     { color: #F7C1C1; }
  .code-str     { color: #FAC775; }
  .code-fn      { color: #9FE1CB; }
  .code-var     { color: #B5D4F4; }

  .setup-step-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--orange);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-bottom: 8px;
    margin-top: 20px;
  }
  .setup-step-label:first-child { margin-top: 0; }

  /* ───── Verification ───── */
  .verify-wrap { max-width: 640px; margin: 0 auto; }
  .verify-wrap h2 {
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 20px;
  }
  .verify-status {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 24px;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .status-indicator {
    width: 10px; height: 10px; border-radius: 50%;
    flex-shrink: 0;
  }
  .indicator-pulse {
    background: var(--amber);
    animation: pulse 1.5s infinite ease-in-out;
  }
  .indicator-green { background: var(--green); }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(239, 159, 39, 0.5); }
    50% { box-shadow: 0 0 0 8px rgba(239, 159, 39, 0); }
  }
  .status-title { font-size: 14px; font-weight: 500; }
  .status-sub { font-size: 12px; color: var(--text-3); margin-top: 2px; }

  .live-feed {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  .live-feed-head {
    padding: 12px 18px;
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .live-feed-head span { font-size: 12px; font-weight: 500; color: var(--text-2); }
  .live-feed-head .live {
    font-size: 10px; color: var(--green); font-weight: 500;
    display: flex; align-items: center; gap: 6px;
  }
  .live-feed-head .live::before {
    content: ''; width: 6px; height: 6px; background: var(--green); border-radius: 50%;
    animation: pulse-green 1.5s infinite;
  }
  @keyframes pulse-green {
    0%, 100% { opacity: 1; } 50% { opacity: 0.4; }
  }
  .feed-row {
    padding: 10px 18px;
    border-bottom: 1px solid var(--border);
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: 14px;
    align-items: center;
    font-size: 12px;
    animation: slideIn 0.3s ease-out;
  }
  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .feed-row:last-child { border-bottom: none; }
  .feed-time { color: var(--text-3); font-family: var(--mono); font-size: 11px; }
  .feed-model {
    background: var(--bg);
    padding: 2px 8px;
    border-radius: 4px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-2);
  }
  .feed-tokens { color: var(--text-2); font-variant-numeric: tabular-nums; }
  .feed-cost { color: var(--amber); font-weight: 500; font-variant-numeric: tabular-nums; }

  .email-preview {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    margin: 0 auto;
    max-width: 620px;
  }
  .email-header {
    padding: 16px 22px;
    border-bottom: 1px solid var(--border);
    background: var(--bg-2);
  }
  .email-from { font-size: 12px; color: var(--text-3); margin-bottom: 4px; }
  .email-subject { font-size: 17px; font-weight: 600; }
  .email-body { padding: 24px 22px; }
  .email-hello { font-size: 14px; color: var(--text-2); margin-bottom: 18px; }
  .email-big-num {
    background: linear-gradient(135deg, rgba(226, 75, 74, 0.1), rgba(226, 75, 74, 0.02));
    border: 1px solid rgba(226, 75, 74, 0.3);
    border-radius: 10px;
    padding: 18px 22px;
    margin-bottom: 20px;
    text-align: center;
  }
  .email-big-num .n {
    font-size: 38px;
    font-weight: 600;
    color: var(--red);
    line-height: 1.1;
  }
  .email-big-num .l {
    font-size: 12px;
    color: var(--text-2);
    margin-top: 4px;
  }
  .email-finding-list { margin-bottom: 20px; }
  .email-finding {
    display: grid;
    grid-template-columns: 6px 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .email-finding:last-child { border-bottom: none; }
  .ef-dot { width: 6px; height: 6px; border-radius: 50%; }
  .ef-title { font-size: 13px; }
  .ef-val { font-size: 13px; font-weight: 500; }

  /* ───── CTO Dashboard ───── */
  .dashboard {
    display: grid;
    grid-template-columns: 220px 1fr;
    height: 100%;
    background: var(--bg-2);
    border-radius: 12px;
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .sidebar {
    background: var(--bg);
    border-right: 1px solid var(--border);
    padding: 20px 12px;
  }
  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    padding: 0 8px;
  }
  .sidebar-logo .mark {
    width: 22px; height: 22px;
    background: var(--orange);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 700;
    font-size: 11px;
  }
  .sidebar-logo .name { font-weight: 600; font-size: 14px; }
  .sidebar-section {
    font-size: 10px;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding: 8px;
    margin-top: 12px;
  }
  .sidebar-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 10px;
    border-radius: 6px;
    font-size: 13px;
    color: var(--text-2);
    cursor: pointer;
    margin-bottom: 1px;
  }
  .sidebar-item:hover { background: var(--card); }
  .sidebar-item.active { background: var(--card); color: var(--text); }
  .sidebar-item .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--border-2);
    flex-shrink: 0;
  }
  .sidebar-item.active .dot { background: var(--orange); }
  .sidebar-badge {
    margin-left: auto;
    font-size: 10px;
    background: rgba(226, 75, 74, 0.18);
    color: var(--red);
    padding: 1px 6px;
    border-radius: 8px;
    font-weight: 500;
  }

  .dashboard-main {
    padding: 24px 28px;
    overflow-y: auto;
  }
  .dashboard-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .dashboard-head h1 { font-size: 22px; font-weight: 600; margin-bottom: 4px; }
  .dashboard-head .sub { font-size: 12px; color: var(--text-3); }
  .dashboard-head .actions { display: flex; gap: 8px; }

  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 20px;
  }
  .kpi {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
  }
  .kpi-label {
    font-size: 11px; color: var(--text-3);
    text-transform: uppercase; letter-spacing: 0.5px;
    margin-bottom: 6px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .kpi-value { font-size: 22px; font-weight: 600; line-height: 1.2; margin-bottom: 4px; }
  .kpi-delta { font-size: 11px; font-weight: 500; }
  .kpi-delta.up { color: var(--red); }
  .kpi-delta.down { color: var(--green); }
  .kpi-sub { font-size: 11px; color: var(--text-3); }

  .panel-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 14px;
    margin-bottom: 20px;
  }
  .panel {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 18px;
  }
  .panel h3 {
    font-size: 13px; font-weight: 600;
    margin-bottom: 12px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .panel h3 .view-all { font-size: 11px; color: var(--teal); font-weight: 400; cursor: pointer; }

  .driver-row {
    display: grid;
    grid-template-columns: 20px 1fr 100px 70px;
    gap: 10px;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    font-size: 12px;
  }
  .driver-row:last-child { border-bottom: none; }
  .driver-rank {
    color: var(--text-3);
    font-family: var(--mono);
    font-size: 11px;
  }
  .driver-name { font-weight: 500; }
  .driver-owner { font-size: 11px; color: var(--text-3); }
  .driver-bar {
    height: 4px; background: var(--bg); border-radius: 2px; overflow: hidden;
  }
  .driver-bar .fill { height: 100%; background: var(--orange); border-radius: 2px; }
  .driver-cost {
    text-align: right;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .violation-row {
    display: grid;
    grid-template-columns: 8px 1fr auto;
    gap: 10px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .violation-row:last-child { border-bottom: none; }
  .v-dot { width: 6px; height: 6px; border-radius: 50%; }
  .v-title { font-size: 12px; font-weight: 500; margin-bottom: 2px; }
