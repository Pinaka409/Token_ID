      if (n < step) d.classList.add('complete');
      if (n === step) d.classList.add('active');
    });

    document.getElementById('url-bar').textContent = urls[step];
    document.getElementById('context-text').innerHTML = contexts[step];

    // Reset verify step if needed
    if (step === 5) {
      resetVerify();
    }
  }

  function next() {
    if (step < totalSteps) { step++; render(); }
  }
  function prev() {
    if (step > 1) { step--; render(); }
  }
  function goTo(n) {
    step = n; render();
  }
  function reset() {
    step = 1; render();
  }

  // Verify screen simulation
  let feedCalls = [];
  function resetVerify() {
    feedCalls = [];
    document.getElementById('feed-body').innerHTML = '<div style="padding: 28px; text-align: center; color: var(--text-3); font-size: 12px;">No calls received yet. Waiting...</div>';
    document.getElementById('status-indicator').className = 'status-indicator indicator-pulse';
    document.getElementById('status-title').textContent = 'Listening on your API key';
    document.getElementById('status-sub').textContent = "Make any API call in your app — we'll detect it automatically.";
    document.getElementById('live-indicator').style.display = 'none';
    document.getElementById('to-email-btn').classList.add('hidden');
    document.getElementById('trigger-call-btn').classList.remove('hidden');
  }

  function triggerFirstCall() {
    document.getElementById('status-indicator').className = 'status-indicator indicator-green';
    document.getElementById('status-title').textContent = 'Connected ✓';
    document.getElementById('status-sub').textContent = 'Collecting your first 24 hours. We will email you when findings are ready.';
    document.getElementById('live-indicator').style.display = 'flex';
    document.getElementById('trigger-call-btn').classList.add('hidden');

    const feed = document.getElementById('feed-body');
    feed.innerHTML = '';

    const calls = [
      { time: '14:32:08', model: 'claude-sonnet-4-5', tokens: '847', cost: '$0.0041' },
      { time: '14:32:11', model: 'claude-sonnet-4-5', tokens: '1,204', cost: '$0.0058' },
      { time: '14:32:14', model: 'gpt-4o-mini', tokens: '392', cost: '$0.0003' },
      { time: '14:32:18', model: 'claude-sonnet-4-5', tokens: '2,187', cost: '$0.0098' },
      { time: '14:32:22', model: 'claude-haiku', tokens: '514', cost: '$0.0004' },
    ];

    calls.forEach((c, i) => {
      setTimeout(() => {
        const row = document.createElement('div');
        row.className = 'feed-row';
        row.innerHTML = `
          <div class="feed-time">${c.time}</div>
          <div class="feed-model">${c.model}</div>
          <div class="feed-tokens">${c.tokens} tokens</div>
          <div class="feed-cost">${c.cost}</div>
        `;
        feed.insertBefore(row, feed.firstChild);

        if (i === 2) {
          document.getElementById('to-email-btn').classList.remove('hidden');
        }
      }, i * 600);
    });
  }

  render();
</script>

</body>
</html>
